        // --- MODULE: TEACHER WORKSHEET ---
        window.generateWorksheet = function() {
            const chapter = document.getElementById('teacher-chapter').value;
            const count = parseInt(document.getElementById('teacher-count').value) || 10;
            const wsType = document.getElementById('teacher-type').value;

            let validKeys = Object.keys(window.dimDict).filter(k => !k.startsWith('__TMP') && window.dimDict[k].name !== 'Length' && window.dimDict[k].name !== 'Distance');
            if (chapter !== 'all') validKeys = validKeys.filter(k => window.dimDict[k].chapter === chapter);

            let jeePool = window.jeePYQBank;
            if (chapter !== 'all') jeePool = window.jeePYQBank.filter(q => q.ch === chapter);
            if (jeePool.length === 0) jeePool = window.jeePYQBank;

            let questions = [], answers = [];

            if (wsType === 'standard' || wsType === 'mixed') {
                let stdCount = wsType === 'mixed' ? Math.ceil(count / 2) : count;
                for (let i = 0; i < stdCount; i++) {
                    const randomKey = validKeys[Math.floor(Math.random() * validKeys.length)];
                    const d = window.dimDict[randomKey];
                    questions.push({
                        num: questions.length + 1,
                        type: 'standard',
                        text: `Derive the dimensional formula for <strong>${d.name}</strong>.`,
                        answer: `${d.name} = ${window.formatDim(d)}`,
                        hint: `Derivation: ${d.concept.join(` ${d.op||'â†’'} `)}`
                    });
                }
            }

            if (wsType === 'jee' || wsType === 'mixed') {
                let jeeCount = wsType === 'mixed' ? Math.floor(count / 2) : count;
                let usedIds = new Set();
                for (let i = 0; i < jeeCount; i++) {
                    let available = jeePool.filter(q => !usedIds.has(q.id));
                    if (available.length === 0) { available = jeePool; usedIds = new Set(); }
                    const q = available[Math.floor(Math.random() * available.length)];
                    usedIds.add(q.id);
                    const optLetters = ['A', 'B', 'C', 'D'];
                    const optHtml = q.options.map((o, idx) => `<li style="margin-bottom:0.3rem;">(${optLetters[idx]}) ${o}</li>`).join('');
                    questions.push({
                        num: questions.length + 1,
                        type: 'jee',
                        text: `<span style="font-size:0.8rem;color:#555;font-weight:bold;">[${q.source}]</span><br>${q.question}<br><ul style="list-style:none;padding-left:1rem;margin-top:0.5rem;">${optHtml}</ul>`,
                        answer: `(${optLetters[q.answer]}) ${q.options[q.answer]}`,
                        hint: q.explanation
                    });
                }
            }

            // Shuffle combined questions
            questions.sort(() => Math.random() - 0.5);
            questions.forEach((q, i) => q.num = i + 1);

            const qHtml = questions.map(q =>
                `<div style="margin-bottom:${q.type==='jee'?'2.5':'3'}rem; page-break-inside:avoid;">
                    <div style="font-size:1rem;"><strong>Q${q.num}.</strong> ${q.text}</div>
                    ${q.type === 'standard' ? `<div style="border-bottom:1px dotted #aaa;margin-top:2rem;width:100%;"></div>` : ''}
                </div>`
            ).join('');

            const ansHtml = questions.map(q =>
                `<div style="margin-bottom:1rem; border-left:3px solid ${q.type==='jee'?'#3b82f6':'#22c55e'}; padding-left:0.75rem;">
                    <strong>Q${q.num}.</strong> ${q.answer}<br>
                    <span style="color:#555;font-size:0.9rem;">${q.hint}</span>
                </div>`
            ).join('');

            const typeLabel = wsType === 'jee' ? 'JEE PYQ MCQ Mode' : wsType === 'mixed' ? 'Mixed Mode (Standard + JEE PYQ)' : 'Standard Mode';
            const chapterLabel = chapter === 'all' ? 'All Chapters' : chapter.charAt(0).toUpperCase() + chapter.slice(1);

            const html = `<!DOCTYPE html>
<html><head><title>CinePhysicsHQ â€” Dimensional Analysis Worksheet</title>
<style>
  body { font-family: Arial, sans-serif; padding: 2rem; max-width: 850px; margin: 0 auto; line-height: 1.7; color: #111; }
  h1 { text-align: center; border-bottom: 3px solid #3b82f6; padding-bottom: 0.5rem; color: #1e293b; }
