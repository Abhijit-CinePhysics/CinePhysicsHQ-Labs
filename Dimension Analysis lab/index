  .badge { display:inline-block; background:#dbeafe; color:#1d4ed8; padding:0.2rem 0.6rem; border-radius:4px; font-size:0.85rem; margin-bottom:1rem; }
  h2 { color: #1e293b; border-top: 2px dashed #cbd5e1; padding-top: 1rem; margin-top: 3rem; }
  .ans-block { background:#f8fafc; border-radius:6px; padding:1rem; }
  .footer { text-align:center; margin-top:3rem; color:#94a3b8; font-size:0.85rem; border-top:1px solid #e2e8f0; padding-top:1rem; }
  @media print { .no-print { display: none; } body { padding: 1rem; } }
</style></head><body>
<button class="no-print" style="padding:10px 20px;font-size:16px;margin-bottom:20px;cursor:pointer;background:#3b82f6;color:white;border:none;border-radius:6px;" onclick="window.print()">ðŸ–¨ï¸ Print Worksheet</button>
<h1>âš¡ Dimensional Analysis Practice</h1>
<div class="meta">
  <span>Name: _________________________</span>
  <span>Date: ____________</span>
  <span>Score: _____ / ${questions.length}</span>
</div>
<div>
  <span class="badge">ðŸ“š Chapter: ${chapterLabel}</span>
  <span class="badge" style="background:#dcfce7;color:#166534;margin-left:0.5rem;">ðŸŽ¯ ${typeLabel}</span>
  <span class="badge" style="background:#fef9c3;color:#92400e;margin-left:0.5rem;">Questions: ${questions.length}</span>
</div>
<p style="color:#475569;font-style:italic;margin-bottom:2rem;">Instructions: ${wsType!=='standard' ? 'For MCQ questions, circle the correct option. For standard questions, show your dimensional derivation step by step.' : 'Write the dimensional formula for each physical quantity. Show your derivation steps clearly.'}</p>
<div class="q-list">${qHtml}</div>
<h2>ðŸ“‹ Answer Key <span style="font-weight:normal;font-size:0.9rem;color:#475569;">(For Teacher Use Only)</span></h2>
<div class="ans-block">${ansHtml}</div>
<div class="footer">Generated by <strong>CinePhysicsHQ-Labs</strong> | Dimensional Analysis Lab | abhijit-cinephysics.github.io</div>
</body></html>`;

            const newWin = window.open('', '_blank');
            newWin.document.write(html);
            newWin.document.close();
        }

