            if (dim.mol) str += 'mol' + (dim.mol !== 1 ? window.toSuperscript(dim.mol) : '');
            return str === '' ? 'Dimensionless' : '[' + str + ']';
        }
        window.isDimensionless = function(dim) { return dim.M === 0 && dim.L === 0 && dim.T === 0 && dim.I === 0 && dim.K === 0 && dim.mol === 0; }
        window.operateDims = function(d1, d2, op, scalar = 1) {
            let res = {M:0, L:0, T:0, I:0, K:0, mol:0};
            for(let k in res) res[k] = op === 'add' ? d1[k] + (d2[k] * scalar) : d1[k] - d2[k];
            return res;
        }

        window.parseFlatMultiplication = function(expr) {
            let result = {M:0, L:0, T:0, I:0, K:0, mol:0};
            
            expr = expr.replace(/([0-9])([a-zA-ZÏ€])/g, '$1 * $2');
            expr = expr.replace(/\*/g, ' '); 
            
            const regex = /(__TMP_\d+__|[a-zA-Z_0-9Ï€]+)([\Â²\Â³\â´\âµ\â»]|\^(?:\-?\d*\.?\d+|\(\-?\d+\/\d+\)))?/g;
            let match;
            
            while ((match = regex.exec(expr)) !== null) {
                let rawVar = match[1];
                let vLower = rawVar.toLowerCase();
                let variable = null;
                
                if(vLower === 'ke') variable = 'KE'; 
                else if(vLower === 'pe') variable = 'PE'; 
                else if(vLower === 'pr') variable = 'Pr';
                else if(window.aliasMap[rawVar]) variable = window.aliasMap[rawVar];
                else if(window.aliasMap[vLower]) variable = window.aliasMap[vLower];
                else if(window.dimDict[rawVar]) variable = rawVar;
                
                if(variable && (window.mathFuncNames.includes(variable) || !isNaN(variable))) continue; 
                if(!variable && !isNaN(rawVar)) continue;
                // CRITICAL FIX: skip if the raw token itself is a math function (e.g. 'sqrt', 'sin', 'cos')
                // without this, 'sqrt' falls into char-split â†’ s, q, r, t are each looked up as physics vars
                if(window.mathFuncNames.includes(vLower)) continue;

                let powerStr = match[2] || "1";
                let power = 1;
                
                if(powerStr.startsWith('^(')) {
                    let parts = powerStr.replace('^(', '').replace(')', '').split('/');
                    power = parseFloat(parts[0]) / parseFloat(parts[1]);
                } else {
                    power = parseFloat(powerStr.replace('Â²', '2').replace('Â³', '3').replace('â´', '4').replace('âµ', '5').replace('â»', '-').replace('^', ''));
                }
                
                if (variable && window.dimDict[variable]) {
                    result = window.operateDims(result, window.dimDict[variable], 'add', power);
                } else if (!variable) {
                    // This block fixes Bug 1: Splitting implicit equations like "mc2"
                    let chars = rawVar.split('');
                    let tempDims = {M:0, L:0, T:0, I:0, K:0, mol:0};
                    let allRecognized = true;
                    
                    let i = 0;
                    while (i < chars.length) {
                        let char = chars[i];
                        let charMapped = window.aliasMap[char] || window.aliasMap[char.toLowerCase()] || char;
                        
                        if (window.dimDict[charMapped]) {
                            let charPower = 1;
                            let nextIdx = i + 1;
                            let powStr = "";
                            
                            // Check if the directly following characters are numbers (e.g. the "2" in "mc2")
                            while(nextIdx < chars.length && /[0-9\.\-]/.test(chars[nextIdx])) {
                                powStr += chars[nextIdx];
                                nextIdx++;
                            }
                            if(powStr !== "" && powStr !== "-" && powStr !== ".") {
                                charPower = parseFloat(powStr);
                                i = nextIdx - 1; // skip past the numbers
                            }
                            // Add to tempDims for this character
                            tempDims = window.operateDims(tempDims, window.dimDict[charMapped], 'add', charPower);
                        } else if (/[0-9\.\-]/.test(char)) {
                            // Safely ignore stray mathematical coefficients
                        } else {
                            allRecognized = false;
                            break;
                        }
                        i++;
                    }
                    if (allRecognized) {
                        result = window.operateDims(result, tempDims, 'add', power);
                    }
                }
            }
            return result;
        }

        window.parseDivision = function(expr) {
            let parts = expr.split('/');
            let result = window.parseFlatMultiplication(parts[0]);
            for(let i = 1; i < parts.length; i++) result = window.operateDims(result, window.parseFlatMultiplication(parts[i]), 'subtract');
            return result;
        }

        window.activeTempTokens = [];

        // ---------------------------------------------------------------
        // HELPER: Resolve dimension of a single function application
        // funcName: string like 'sqrt', 'sin', 'diff', 'int'
        // innerDim: dimension object of the argument
        // extraArg: for diff/int, the dimension of the differential variable
        // returns: { dim, error } or just dim object
        // ---------------------------------------------------------------
        window.applyFuncDim = function(funcName, innerDim, extraArg) {
            const rule = window.mathFuncRules[funcName] || 'dimensionless_arg_out';
            const zero = {M:0, L:0, T:0, I:0, K:0, mol:0};

            if (rule === 'sqrt') {
                let d = {}; for(let k in innerDim) d[k] = innerDim[k] * 0.5; return { dim: d };
            }
            if (rule === 'cbrt') {
                let d = {}; for(let k in innerDim) d[k] = innerDim[k] / 3; return { dim: d };
            }
            if (rule === 'preserve') {
                return { dim: { ...innerDim } };
            }
            if (rule === 'dimensionless_arg_out') {
                if (!window.isDimensionless(innerDim)) {
                    const argStr = window.formatDim(innerDim);
                    return { error: `Argument of ${funcName}() must be dimensionless (received ${argStr}). Remember: angles in radians are dimensionless.` };
                }
                return { dim: { ...zero } };
            }
            if (rule === 'diff') {
                // diff(f, x) â†’ [f] / [x]  (derivative of f w.r.t. x)
                // extraArg = dimension of the differential variable
                if (!extraArg) return { error: `diff() needs two arguments: diff(function, variable). E.g. diff(v, t) for dv/dt.` };
                let d = window.operateDims(innerDim, extraArg, 'subtract');
                return { dim: d };
            }
            if (rule === 'integral') {
                // int(f, x) â†’ [f] Ã— [x]  (integral of f w.r.t. x)
                if (!extraArg) return { error: `int() needs two arguments: int(function, variable). E.g. int(F, s) for âˆ«FÂ·ds.` };
                let d = window.operateDims(innerDim, extraArg, 'add');
                return { dim: d };
            }
            // fallback
            return { dim: { ...zero } };
        };

        // ---------------------------------------------------------------
        // PREPROCESSOR: Handle special notations before recursive eval
        //   d(f)/d(x)  â†’  diff(f, x)
        //   df/dx      â†’  diff(f, x)  (Leibniz shorthand)
        //   e^(...)    â†’  exp(...)
        //   |expr|     â†’  abs(expr)
        // ---------------------------------------------------------------
        window.preprocessExpression = function(expr) {
            // e^(...) â†’ exp(...)
            expr = expr.replace(/\be\s*\^\s*\(/g, 'exp(');
            expr = expr.replace(/\be\s*\^\s*(-?\d+\.?\d*)/g, 'exp($1)');

            // |expr| â†’ abs(expr)   â€” simple single-level only
            expr = expr.replace(/\|([^|]+)\|/g, 'abs($1)');

            // d(f)/d(x) â†’ diff(f, x)
            expr = expr.replace(/d\s*\(([^)]+)\)\s*\/\s*d\s*\(([^)]+)\)/g, 'diff($1, $2)');

            // df/dx  (single letter Leibniz) â†’ diff(f, x)
            // Matches "d" + word + "/" + "d" + word but NOT "d" standalone
            expr = expr.replace(/\bd([A-Za-z_]\w*)\s*\/\s*d([A-Za-z_]\w*)/g, 'diff($1, $2)');

            // âˆ‚f/âˆ‚x (partial) â†’ diff(f, x)
            expr = expr.replace(/âˆ‚([A-Za-z_]\w*)\s*\/\s*âˆ‚([A-Za-z_]\w*)/g, 'diff($1, $2)');

            // dÂ²f/dxÂ²  (second derivative) â†’ diff(diff(f, x), x)
            expr = expr.replace(/d\^2\s*([A-Za-z_]\w*)\s*\/\s*d([A-Za-z_]\w*)\^2/g, 'diff(diff($1, $2), $2)');
            expr = expr.replace(/dÂ²([A-Za-z_]\w*)\s*\/\s*d([A-Za-z_]\w*)Â²/g, 'diff(diff($1, $2), $2)');

            // âˆ«f dx  â†’  int(f, x)   (simple inline integral notation)
            expr = expr.replace(/âˆ«\s*([A-Za-z_]\w*)\s+d([A-Za-z_]\w*)/g, 'int($1, $2)');

            // Normalize ** to ^ (Python-style power)
            expr = expr.replace(/\*\*/g, '^');

            return expr;
        };

        window.evaluateTermRecursively = function(term) {
            // Run preprocessor first
            let currentStr = window.preprocessExpression(term.trim());
            let tempCounter = 0;

            // Iteratively resolve innermost parentheses
            let safetyLimit = 60;
            while (currentStr.includes('(') && safetyLimit-- > 0) {
                let lastOpen = currentStr.lastIndexOf('(');
                let nextClose = currentStr.indexOf(')', lastOpen);
                if (nextClose === -1) break;

                let innerRaw = currentStr.substring(lastOpen + 1, nextClose);

                // Detect fraction literals like (1/2) used as exponents â€” don't evaluate as physics
                if (/^\s*-?\d+\.?\d*\s*\/\s*-?\d+\.?\d*\s*$/.test(innerRaw)) break;

                // Find function name immediately before this '('
                let prefix = currentStr.substring(0, lastOpen).trimEnd();
                let funcName = null;
                for (let fn of window.mathFuncNames) {
                    if (prefix.toLowerCase().endsWith(fn.toLowerCase())) {
                        funcName = fn.toLowerCase();
                        break;
                    }
                }

                // For diff() and int() split inner on comma to get two args
                let innerDim = null, extraArgDim = null, evalError = null;

                if (funcName === 'diff' || funcName === 'deriv' ||
                    funcName === 'int'  || funcName === 'integral') {
                    // Split on first top-level comma
                    let commaIdx = -1, depth = 0;
                    for (let ci = 0; ci < innerRaw.length; ci++) {
                        if (innerRaw[ci] === '(') depth++;
                        else if (innerRaw[ci] === ')') depth--;
                        else if (innerRaw[ci] === ',' && depth === 0) { commaIdx = ci; break; }
                    }
                    if (commaIdx === -1) {
                        evalError = `${funcName}() requires two arguments separated by a comma. Example: diff(v, t) or int(F, s)`;
                    } else {
                        let arg1 = innerRaw.substring(0, commaIdx).trim();
                        let arg2 = innerRaw.substring(commaIdx + 1).trim().replace(/^\s*d\s*/, ''); // strip leading 'd' e.g. "dt" â†’ "t"
                        let r1 = window.evaluateTermRecursively(arg1);
                        // Resolve differential variable: diffVarMap first, then dimDict, then full eval
                        let arg2key = arg2.trim();
                        let r2dim = window.diffVarMap[arg2key]
                            || (window.dimDict[arg2key] ? window.dimDict[arg2key] : null)
                            || (window.aliasMap[arg2key] && window.dimDict[window.aliasMap[arg2key]] ? window.dimDict[window.aliasMap[arg2key]] : null);
                        let r2 = r2dim ? { dim: r2dim, error: null } : window.evaluateTermRecursively(arg2);
                        if (r1.error) evalError = r1.error;
                        else if (r2.error) evalError = r2.error;
                        else { innerDim = r1.dim; extraArgDim = r2.dim; }
                    }
                } else {
                    // Standard single-argument function â€” evaluate inner expression
                    let innerTerms = innerRaw.split(/[\+\-](?![^\(]*\))/).map(t => t.trim()).filter(t => t);
                    let firstDim = null, firstDimStr = '';
                    for (let i = 0; i < innerTerms.length; i++) {
                        let ev = window.parseDivision(innerTerms[i]);
                        let ds = window.formatDim(ev);
                        if (i === 0) { firstDim = ev; firstDimStr = ds; }
                        else if (ds !== firstDimStr) {
                            evalError = `Inside ${funcName || 'parentheses'}, cannot combine ${firstDimStr} and ${ds}`;
                            break;
                        }
                    }
                    innerDim = firstDim || {M:0, L:0, T:0, I:0, K:0, mol:0};
                }

                if (evalError) { window.cleanupTempTokens(); return { error: evalError }; }

                // Apply the function's dimensional rule
                let result;
                if (funcName) {
                    result = window.applyFuncDim(funcName, innerDim, extraArgDim);
                    if (result.error) { window.cleanupTempTokens(); return { error: result.error }; }
                } else {
                    // Plain parentheses â€” just carry the inner dimension through
                    result = { dim: innerDim };
                }

                // Check for exponent after closing paren e.g. (...)^2
                let afterParen = currentStr.substring(nextClose + 1);
                let expMatch = afterParen.match(/^([\Â²\Â³\â´\âµ\â»]|\^(?:-?\d*\.?\d+|\(-?\d+\/\d+\)))/);
                let charsToReplace = nextClose + 1;
                let powerToApply = 1;

                if (expMatch && !funcName) {
                    let powerStr = expMatch[1];
                    if (powerStr.startsWith('^(')) {
                        let parts = powerStr.replace('^(', '').replace(')', '').split('/');
                        powerToApply = parseFloat(parts[0]) / parseFloat(parts[1]);
                    } else {
                        powerToApply = parseFloat(
                            powerStr.replace('Â²','2').replace('Â³','3').replace('â´','4')
                                    .replace('âµ','5').replace('â»','-').replace('^','')
                        );
                    }
                    charsToReplace += expMatch[1].length;
                }

                let finalDim = result.dim;
                if (powerToApply !== 1) {
                    finalDim = {};
                    for (let k in result.dim) finalDim[k] = result.dim[k] * powerToApply;
                }

                // Store as temp token
                let tempToken = `__TMP_${tempCounter}__`;
                window.dimDict[tempToken] = { ...finalDim };
                window.activeTempTokens.push(tempToken);
                tempCounter++;

                // Determine how far back to trim (remove function name from prefix)
                let trimStart = lastOpen;
                if (funcName) {
                    let fnStart = prefix.toLowerCase().lastIndexOf(funcName);
                    trimStart = fnStart;
                }
                currentStr = currentStr.substring(0, trimStart) + tempToken + currentStr.substring(charsToReplace);
            }

            return { dim: window.parseDivision(currentStr), error: null };
        }

        window.cleanupTempTokens = function() {
            window.activeTempTokens.forEach(token => delete window.dimDict[token]);
            window.activeTempTokens = [];
        }

        // --- MODULE: EQUATION CHECKER ---
        window.explainTerm = function(term) {
            let explanation = "";
            let processed = new Set();
            
            const regex = /[a-zA-Z_]+/g;
            let match;
            while((match = regex.exec(term)) !== null) {
                let rawVar = match[0];
                let vLower = rawVar.toLowerCase();

                // CRITICAL: Skip & annotate math function names FIRST
                if(window.mathFuncNames.includes(vLower)) {
                    if (!processed.has(vLower)) {
                        const rule = window.mathFuncRules ? (window.mathFuncRules[vLower] || '') : '';
                        let note = '';
                        if (rule === 'sqrt') note = 'âˆš â€” raises dimension to power Â½';
                        else if (rule === 'cbrt') note = 'âˆ› â€” raises dimension to power â…“';
                        else if (rule === 'diff') note = 'derivative â€” output dim = [f]/[variable]';
                        else if (rule === 'integral') note = 'integral â€” output dim = [f]Ã—[variable]';
                        else if (rule === 'preserve') note = 'preserves dimension of argument';
                        else if (rule === 'dimensionless_arg_out') note = 'argument must be dimensionless â†’ output is dimensionless';
                        if (note) explanation += `<span style="color:var(--xp-color); font-size:0.88rem;">âŸ¨${rawVar}âŸ© ${note}</span><br>`;
                        processed.add(vLower);
                    }
                    continue;
                }

                let lookupVar = null;
                if(vLower === 'ke') lookupVar = 'KE';
                else if(vLower === 'pe') lookupVar = 'PE';
                else if(vLower === 'pr') lookupVar = 'Pr';
                else if(window.aliasMap[rawVar]) lookupVar = window.aliasMap[rawVar];
                else if(window.aliasMap[vLower]) lookupVar = window.aliasMap[vLower];
                else if(window.dimDict[rawVar]) lookupVar = rawVar;

                if (lookupVar && window.dimDict[lookupVar]) {
                    if (!processed.has(lookupVar)) {
                        explanation += `<span style="color:var(--text-muted); font-size: 0.95rem;">â†³ ${rawVar} = ${window.dimDict[lookupVar].name} = ${window.formatDim(window.dimDict[lookupVar])}</span><br>`;
                        processed.add(lookupVar);
                    }
                } else if (!lookupVar) {
                    let chars = rawVar.split('');
                    for(let char of chars) {
                        let charMapped = window.aliasMap[char] || window.aliasMap[char.toLowerCase()] || char;
                        if(window.dimDict[charMapped] && !processed.has(charMapped)) {
                            explanation += `<span style="color:var(--text-muted); font-size: 0.95rem;">â†³ ${char} = ${window.dimDict[charMapped].name} = ${window.formatDim(window.dimDict[charMapped])}</span><br>`;
                            processed.add(charMapped);
                        }
                    }
                }
            }
            return explanation;
        }

        window.getDimExplanation = function(lhsObj, rhsObj) {
            let diffs = []; const labels = {M:'Mass', L:'Length', T:'Time', I:'Current', K:'Temperature', mol:'Amount'};
            for(let key in lhsObj) if(lhsObj[key] !== rhsObj[key]) diffs.push(`${labels[key]} exponent differs (LHS: ${lhsObj[key]}, RHS: ${rhsObj[key]})`);
            return diffs.join('<br>â€¢ ');
        }

        window.loadPreset = function(eq) { document.getElementById('equation-input').value = eq; window.verifyEquation(); }

        window.verifyEquation = function() {
            const input = document.getElementById('equation-input').value;
            const outputPanel = document.getElementById('checker-output');
            if (!input.includes('=')) { outputPanel.innerHTML = '<span class="error-text">âŒ Error: Equation must contain an "=" sign.</span>'; return; }
            
            let safeInput = input.replace(/(^|\s)(\d+)\/(\d+)(\s|\*)/g, (match, pre, n, d, post) => pre + (n/d).toString() + post);

            const [lhsRaw, rhsRaw] = safeInput.split('=');
            const lhsTerms = lhsRaw.split(/[\+\-](?![^\(]*\))/).map(t => t.trim()).filter(t => t);
            const rhsTerms = rhsRaw.split(/[\+\-](?![^\(]*\))/).map(t => t.trim()).filter(t => t);
            
            let outputHTML = `<div class="animate-pop">Equation: <strong style="font-size: 1.2rem;">${input}</strong>\n\n`;
            let globalError = null;

            function evaluateSide(sideName, terms) {
                let html = `<div style="margin-bottom:0.5rem;"><strong style="color:var(--accent); font-size:1.1rem;">${sideName} Breakdown:</strong></div>`;
                let firstDimObj = null, firstDimStr = null, isInternallyConsistent = true;
                
                for (let i = 0; i < terms.length; i++) {
                    let evalResult = window.evaluateTermRecursively(terms[i]);
                    if(evalResult.error) { globalError = evalResult.error; return { error: true }; }
                    let dimStr = window.formatDim(evalResult.dim);
                    let explanation = window.explainTerm(terms[i]);

                    html += `<div style="background:rgba(255,255,255,0.02); padding:1rem; border-radius:6px; margin-bottom:1rem; border:1px solid var(--border);">`;
                    html += `<strong>Term:</strong> [${terms[i]}]\n`;
                    if(explanation) html += `${explanation}`;
                    html += `\n<strong>âžœ Result: <span style="color:var(--gold);">${dimStr}</span></strong></div>`;

                    if (i === 0) { firstDimObj = evalResult.dim; firstDimStr = dimStr; }
                    else if (dimStr !== firstDimStr) isInternallyConsistent = false;
                }
                return { html, isInternallyConsistent, dimObj: firstDimObj, dimStr: firstDimStr };
            }

            const lhsData = evaluateSide('LHS', lhsTerms);
            if(globalError) { outputPanel.innerHTML = outputHTML + `<div class="edu-note"><span class="marshall-text">âš¡ Dimension Marshall:</span><br><span class="dialogue-quote">"Math error detected. ${globalError}"</span></div></div>`; window.cleanupTempTokens(); return; }
            
            const rhsData = evaluateSide('RHS', rhsTerms);
            if(globalError) { outputPanel.innerHTML = outputHTML + `<div class="edu-note"><span class="marshall-text">âš¡ Dimension Marshall:</span><br><span class="dialogue-quote">"Math error detected. ${globalError}"</span></div></div>`; window.cleanupTempTokens(); return; }

            outputHTML += lhsData.html + rhsData.html + `<strong>Final Verification:</strong>\n`;
            let marshallTutor = "";
            let pName = window.userStats.playerName || "Cadet";

            if (!lhsData.isInternallyConsistent) {
                outputHTML += `<span class="error-text">âœ– LHS terms are not dimensionally identical.</span>`;
                marshallTutor = `"${pName}, you cannot add apples to oranges. The terms on the left side of the equation have different dimensions."`;
            } else if (!rhsData.isInternallyConsistent) {
                outputHTML += `<span class="error-text">âœ– RHS terms are not dimensionally identical.</span>`;
                marshallTutor = `"The terms on the right side are mathematically incompatible. Check your addition/subtraction."`;
            } else if (lhsData.dimStr !== rhsData.dimStr) {
                outputHTML += `[LHS] = ${lhsData.dimStr}\n[RHS] = ${rhsData.dimStr}\n<span class="error-text">âœ– [LHS] â‰  [RHS] -> Invalid</span>`;
                marshallTutor = `"The dimensions disagree. Here is exactly why:<br>â€¢ ` + window.getDimExplanation(lhsData.dimObj, rhsData.dimObj) + `"`;
            } else {
                outputHTML += `[LHS] = ${lhsData.dimStr}\n[RHS] = ${rhsData.dimStr}\n<span class="success-text">âœ” [LHS] = [RHS] -> Homogeneous</span>`;
                marshallTutor = `"Well done, ${pName}. The equation is perfectly balanced."`;
            }
            
            outputHTML += `\n\n<div class="edu-note"><span class="marshall-text">âš¡ Dimension Marshall:</span><br><span class="dialogue-quote">${marshallTutor}</span></div></div>`;
            outputPanel.innerHTML = outputHTML;
            window.cleanupTempTokens();
        }

        // --- MODULE: QUANTITY DISCOVERY ---
        window.parseDirectDimInput = function() {
            let str = document.getElementById('direct-dim-search').value.replace(/\[|\]/g, '').replace(/\s+/g, '').replace(/\^/g, '').toUpperCase();
            let target = { M:0, L:0, T:0, I:0, K:0, mol:0 };
            const regex = /([MLTIK]|MOL)([\Â²\Â³\â´\âµ\â»]|-?\d*\.?\d+)?/g; let match;
            while((match = regex.exec(str)) !== null) {
                let dim = match[1], pow = parseFloat((match[2] || "1").replace('Â²', '2').replace('Â³', '3').replace('â´', '4').replace('âµ', '5').replace('â»', '-'));
                if(dim === 'M') target.M = pow; if(dim === 'L') target.L = pow; if(dim === 'T') target.T = pow;
                if(dim === 'I') target.I = pow; if(dim === 'K') target.K = pow; if(dim === 'MOL') target.mol = pow;
            }
            document.getElementById('spin-m').value = target.M; document.getElementById('spin-l').value = target.L; document.getElementById('spin-t').value = target.T;
            document.getElementById('spin-i').value = target.I; document.getElementById('spin-k').value = target.K; document.getElementById('spin-mol').value = target.mol;
